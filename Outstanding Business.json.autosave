er of rain on the screen)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"SceneInstancesCount"},"parameters":["","Rain","<","175"]}],"actions":[],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"then we create rain object at random position on X and Y related to camera Borders\nwe repeat the event 3 times, to make the rain spawn faster (3 times per frame)"},{"type":"BuiltinCommonInstructions::Repeat","repeatExpression":"3","conditions":[],"actions":[{"type":{"value":"Create"},"parameters":["","Rain","RandomFloatInRange(CameraBorderLeft()-200,CameraBorderRight()+200)","RandomFloatInRange(CameraBorderTop()-200,CameraBorderTop()-100)",""]},{"type":{"value":"ChangePlan"},"parameters":["Rain","=","1"]}]}]}],"parameters":[]},{"type":"BuiltinCommonInstructions::ForEach","object":"Rain","conditions":[],"actions":[],"events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Splash","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"for each instance of rain we cast a ray toward the angle 90 (to bottom) at 20px (because the rain object height is 20) against the objects to raycast against (level and player)\nso if the raycast got interupted with any of this objects, we store the Y position into the variable FloorYPosition\nthen we change the Rain object Y position set to that variable - 20 (means we push the rain object to the surface of that object)\nand then we change its animation to Splash"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"Raycast"},"parameters":["AllObjectsToRaycastRainAgainst","Rain.CenterX()","Rain.Y()","90","20","","FloorYPosition",""]}],"actions":[{"type":{"value":"MettreY"},"parameters":["Rain","=","FloorYPosition-20"]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["Rain","Animation","=","\"Splash\""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"If the rain top is greater or equal the camera border bottom\nor\nif the rain aniamtion splash has finished\nthen we change the rain object position to the top and at random X position\nthen we set the rain aniamtion back to still\n(so rather than deleting the rain object when the splash animation has finished, or the rain object is out of screen bottom, we change its position back to the top, this is better for performance, since create/delete object eats some performance)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BuiltinCommonInstructions::Or"},"parameters":[],"subInstructions":[{"type":{"value":"BoundingBoxTop"},"parameters":["Rain",">=","CameraBorderBottom()"]},{"type":{"value":"BuiltinCommonInstructions::And"},"parameters":[],"subInstructions":[{"type":{"value":"AnimatableCapability::AnimatableBehavior::Name"},"parameters":["Rain","Animation","=","\"Splash\""]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::HasAnimationEnded"},"parameters":["Rain","Animation"]}]}]}],"actions":[{"type":{"value":"MettreXY"},"parameters":["Rain","=","RandomFloatInRange(CameraBorderLeft()-200,CameraBorderRight()+200)","=","RandomFloatInRange(CameraBorderTop()-200,CameraBorderTop()-100)"]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["Rain","Animation","=","\"Still\""]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Movement","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"for each instance of rain, we simply add a force at 90 angle (to bottom) at 450 pixels speed"},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"AddForceAL"},"parameters":["Rain","90","450",""]}]}],"parameters":[]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Lightning","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"at the beginning of the scene\nwe disable the Brightness layer effect\nand we set the cooldown variable to randomflaot in range between 5 and 20 (used to make the lightning happen at random time between 5-20 seconds)\nthen we start the lightning timer"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"DepartScene"},"parameters":[""]}],"actions":[{"type":{"value":"EnableLayerEffect"},"parameters":["","","\"Brightness\"","no"]},{"type":{"value":"SetNumberVariable"},"parameters":["RandomLightningCooldown","=","RandomFloatInRange(5,20)"]},{"type":{"value":"ResetTimer"},"parameters":["","\"LightningCooldown\""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the timer (we started in the evnet above) is greater or equal to the variable (we set in the event above)\nthen we set the variable to random again\nand we set the Lightning style variable to random between 1 and 2 (this variable is used to make 2 style of lightnings, each with its sound effect and flash style)\nthen we reset the timer"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CompareTimer"},"parameters":["","\"LightningCooldown\"",">=","RandomLightningCooldown"]},{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"SetNumberVariable"},"parameters":["RandomLightningCooldown","=","RandomFloatInRange(5,20)"]},{"type":{"value":"SetNumberVariable"},"parameters":["RandomLigntningStyle","=","RandomInRange(1,2)"]},{"type":{"value":"ResetTimer"},"parameters":["","\"LightningCooldown\""]}],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the variable (set from the event above) was = 1\nthen we turn on the Brightness effect\nand we set the light layer to complete white\nand then we reset them abckj to default values after 0.1 seconds (flash duration)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["RandomLigntningStyle","=","1"]}],"actions":[{"type":{"value":"EnableLayerEffect"},"parameters":["","","\"Brightness\"","yes"]},{"type":{"value":"SetLayerAmbientLightColor"},"parameters":["","","\"255;255;255\""]},{"type":{"value":"Wait"},"parameters":["0.1"]},{"type":{"value":"EnableLayerEffect"},"parameters":["","","\"Brightness\"","no"]},{"type":{"value":"SetLayerAmbientLightColor"},"parameters":["","","\"65;65;65\""]},{"type":{"value":"PlaySoundCanal"},"parameters":["","Thunder.ogg","2","","4","1"]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"same as above but different flash durations"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["RandomLigntningStyle","=","2"]}],"actions":[{"type":{"value":"EnableLayerEffect"},"parameters":["","","\"Brightness\"","yes"]},{"type":{"value":"SetLayerAmbientLightColor"},"parameters":["","","\"255;255;255\""]},{"type":{"value":"Wait"},"parameters":["0.1"]},{"type":{"value":"EnableLayerEffect"},"parameters":["","","\"Brightness\"","no"]},{"type":{"value":"SetLayerAmbientLightColor"},"parameters":["","","\"65;65;65\""]},{"type":{"value":"Wait"},"parameters":["0.1"]},{"type":{"value":"EnableLayerEffect"},"parameters":["","","\"Brightness\"","yes"]},{"type":{"value":"SetLayerAmbientLightColor"},"parameters":["","","\"255;255;255\""]},{"type":{"value":"Wait"},"parameters":["0.1"]},{"type":{"value":"EnableLayerEf